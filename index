<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="manifest" href="./manifest.json">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Orca Player</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jsmediatags/3.9.5/jsmediatags.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }
    body {
      background: #f5f5f7;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 100vh;
      padding: 0;
      margin: 0;
    }
    #app {
      width: 100%;
      max-width: 480px;
      background: white;
      min-height: 100vh;
      position: relative;
      box-shadow: 0 0 30px rgba(0,0,0,0.1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    header {
      background: white;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid #f0f0f0;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .app-icon {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      background: #1e1e2f;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 22px;
      background-image: url('https://k.top4top.io/p_3816zm6mf0.png');
      background-size: cover;
      background-position: center;
      background-color: #1e1e2f;
    }
    .app-name {
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: #1e1e2f;
      font-family: 'Segoe UI', 'Arial Black', sans-serif;
    }
    .header-actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }
    .settings-icon, .search-icon {
      font-size: 1.6rem;
      color: #555;
      cursor: pointer;
      padding: 8px;
      border-radius: 50%;
      transition: background 0.2s;
    }
    .settings-icon:hover, .search-icon:hover {
      background: #f0f0f0;
    }
    .search-bar-container {
      background: white;
      padding: 0 16px 12px;
      border-bottom: 1px solid #f0f0f0;
    }
    .search-bar-inner {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #f2f2f7;
      border-radius: 30px;
      padding: 8px 16px;
    }
    .search-bar-inner i {
      color: #888;
    }
    .search-bar-inner input {
      flex: 1;
      border: none;
      outline: none;
      background: transparent;
      font-size: 1rem;
    }
    .tabs-container {
      display: flex;
      gap: 8px;
      padding: 12px 16px;
      overflow-x: auto;
      background: white;
      border-bottom: 1px solid #f0f0f0;
    }
    .tab {
      padding: 8px 18px;
      background: #f0f0f5;
      border-radius: 30px;
      font-weight: 600;
      font-size: 0.9rem;
      color: #333;
      white-space: nowrap;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
      outline: none;
    }
    .tab.active {
      background: #1e1e2f;
      color: white;
    }
    .content {
      flex: 1;
      overflow-y: auto;
      padding: 8px 16px;
      padding-bottom: 100px;
    }
    .song-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 10px;
      border-radius: 18px;
      margin-bottom: 4px;
      cursor: pointer;
      transition: background 0.15s;
    }
    .song-item:hover { background: #f8f8fc; }
    .song-thumb {
      width: 50px;
      height: 50px;
      border-radius: 14px;
      background: #e0e0e8;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }
    .song-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .song-thumb i { font-size: 28px; color: #777; }
    .song-info { flex: 1; min-width: 0; }
    .song-title {
      font-weight: 700;
      font-size: 1rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: #1e1e2f;
    }
    .song-artist {
      font-size: 0.8rem;
      color: #666;
      margin-top: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .playlist-checkbox {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      border: 2px solid #ccc;
      margin-right: 8px;
      cursor: pointer;
      transition: all 0.2s;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .playlist-checkbox.checked {
      background: #007aff;
      border-color: #007aff;
    }
    .playlist-checkbox.checked::after {
      content: "✓";
      color: white;
      font-weight: bold;
      font-size: 14px;
    }
    .grid-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    .card {
      background: #f9f9fd;
      border-radius: 20px;
      padding: 16px;
      cursor: pointer;
      transition: transform 0.1s;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .card:active { transform: scale(0.97); }
    .card img { width: 80px; height: 80px; border-radius: 20px; object-fit: cover; margin-bottom: 10px; }
    .card i.fa-music { font-size: 48px; color: #aaa; margin-bottom: 8px; }
    .card .card-name { font-weight: 700; font-size: 0.9rem; color: #1e1e2f; }
    .card .card-count { font-size: 0.7rem; color: #888; }
    .btn {
      background: #1e1e2f;
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 30px;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.9rem;
      transition: opacity 0.2s;
    }
    .btn:active { opacity: 0.8; }
    .player-fullscreen {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: white;
      z-index: 100;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    .player-fullscreen.open { transform: translateY(0); }
    .close-player {
      position: absolute;
      top: 20px; left: 20px;
      font-size: 1.8rem;
      color: #333;
      cursor: pointer;
      z-index: 5;
    }
    .cd-container {
      width: 240px;
      height: 240px;
      border-radius: 50%;
      background: #1e1e2f;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 30px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }
    .cd-art {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      overflow: hidden;
      background: #333;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cd-art img { width: 100%; height: 100%; object-fit: cover; }
    .cd-art i { font-size: 60px; color: #bbb; }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .cd-container.playing .cd-art { animation: spin 4s linear infinite; }
    .now-title {
      font-size: 1.4rem;
      font-weight: 800;
      color: #1e1e2f;
      text-align: center;
      margin-bottom: 6px;
      max-width: 90%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .now-artist { font-size: 1rem; color: #666; margin-bottom: 24px; }
    .seek-container {
      width: 100%;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.8rem;
      color: #555;
    }
    .seek-bar {
      flex: 1;
      height: 5px;
      background: #e0e0e0;
      border-radius: 5px;
      cursor: pointer;
    }
    .seek-fill {
      height: 100%;
      background: #1e1e2f;
      border-radius: 5px;
      width: 0%;
      transition: width 0.1s linear;
    }
    .controls-row {
      display: flex;
      align-items: center;
      gap: 30px;
      margin-bottom: 30px;
    }
    .ctrl-btn { font-size: 2.4rem; color: #1e1e2f; cursor: pointer; }
    .ctrl-btn.small { font-size: 1.8rem; }
    .ctrl-btn.play-btn { font-size: 3.2rem; }
    .extra-actions {
      display: flex;
      gap: 20px;
      align-items: center;
      margin-top: 10px;
    }
    .extra-btn { font-size: 1.5rem; color: #555; cursor: pointer; padding: 6px; border-radius: 50%; }
    .extra-btn.active { color: #007aff; background: #e8f0fe; }
    .mini-player {
      position: fixed;
      bottom: 20px;
      left: 20px; right: 20px;
      max-width: 440px;
      margin: 0 auto;
      background: white;
      border-radius: 30px;
      padding: 10px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      z-index: 50;
      cursor: pointer;
      transition: 0.3s;
    }
    .mini-player.hidden { transform: translateY(120px); }
    .mini-thumb { width: 46px; height: 46px; border-radius: 14px; background: #ddd; }
    .mini-thumb img { width: 100%; height: 100%; border-radius: 14px; object-fit: cover; }
    .mini-info { flex: 1; }
    .mini-title { font-weight: 700; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mini-artist { font-size: 0.75rem; color: #777; }
    .mini-play { font-size: 1.8rem; color: #1e1e2f; }
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal { background: white; border-radius: 28px; padding: 24px; width: 100%; max-width: 380px; }
    .modal input { width: 100%; padding: 14px; border-radius: 16px; border: 1px solid #ddd; margin: 16px 0; font-size: 1rem; }
    .perm-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.85);
      color: white;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 999;
      text-align: center;
      padding: 20px;
    }
    .perm-overlay .perm-icon { font-size: 64px; margin-bottom: 20px; }
    .perm-overlay h2 { margin-bottom: 20px; }
    .hidden { display: none !important; }
  </style>
</head>
<body>
<div id="app">
  <!-- Permission Overlay (hidden after first selection) -->
  <div class="perm-overlay hidden" id="permOverlay">
    <i class="fa-solid fa-folder-open perm-icon"></i>
    <h2>Welcome to Orca Player</h2>
    <p style="margin-bottom:30px;">Tap below to grant access to your music folder.</p>
    <button class="btn" id="permSelectBtn" style="font-size:1.2rem; padding:16px 40px;"><i class="fa-solid fa-music"></i> Select Music Folder</button>
  </div>

  <header>
    <div class="header-left">
      <div class="app-icon"></div>
      <span class="app-name">Orca Player</span>
    </div>
    <div class="header-actions">
      <i class="fa-solid fa-magnifying-glass search-icon" id="searchToggleBtn" title="Search"></i>
      <i class="fa-solid fa-gear settings-icon" id="settingsBtn" title="Reselect music folder"></i>
    </div>
  </header>

  <!-- Search Bar -->
  <div class="search-bar-container hidden" id="searchBarContainer">
    <div class="search-bar-inner">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="text" id="searchInput" placeholder="Search songs, artists, albums...">
    </div>
  </div>

  <div class="tabs-container">
    <button class="tab active" data-tab="music">Music</button>
    <button class="tab" data-tab="playlist">Playlist</button>
    <button class="tab" data-tab="album">Album</button>
    <button class="tab" data-tab="artist">Artist</button>
  </div>

  <div class="content" id="contentArea"></div>

  <!-- Mini Player -->
  <div class="mini-player hidden" id="miniPlayer">
    <div class="mini-thumb" id="miniThumb"><i class="fa-solid fa-music"></i></div>
    <div class="mini-info">
      <div class="mini-title" id="miniTitle">No track</div>
      <div class="mini-artist" id="miniArtist">--</div>
    </div>
    <i class="fa-solid fa-play mini-play" id="miniPlayBtn"></i>
  </div>

  <!-- Full Player -->
  <div class="player-fullscreen" id="playerFullscreen">
    <i class="fa-solid fa-chevron-down close-player" id="closePlayerBtn"></i>
    <div class="cd-container" id="cdContainer">
      <div class="cd-art" id="cdArt"><i class="fa-solid fa-music"></i></div>
    </div>
    <div class="now-title" id="nowTitle">Select a song</div>
    <div class="now-artist" id="nowArtist"></div>
    <div class="seek-container">
      <span id="currentTime">0:00</span>
      <div class="seek-bar" id="seekBar"><div class="seek-fill" id="seekFill"></div></div>
      <span id="totalTime">0:00</span>
    </div>
    <div class="controls-row">
      <i class="fa-solid fa-backward-step ctrl-btn small" id="prevBtn"></i>
      <i class="fa-solid fa-play ctrl-btn play-btn" id="playPauseBtn"></i>
      <i class="fa-solid fa-forward-step ctrl-btn small" id="nextBtn"></i>
    </div>
    <div class="extra-actions">
      <i class="fa-regular fa-heart extra-btn" id="loveBtn"></i>
      <i class="fa-solid fa-repeat extra-btn" id="repeatBtn"></i>
      <i class="fa-solid fa-shuffle extra-btn" id="shuffleBtn"></i>
    </div>
  </div>

  <!-- Modals -->
  <div class="modal-overlay hidden" id="playlistModal">
    <div class="modal">
      <h3>New Playlist</h3>
      <input type="text" id="playlistNameInput" placeholder="Playlist name">
      <button class="btn" id="createPlaylistBtn">Create</button>
      <button class="btn" style="background:#ccc; margin-top:8px;" id="cancelPlaylistBtn">Cancel</button>
    </div>
  </div>
  <div class="modal-overlay hidden" id="songSelectModal">
    <div class="modal" style="max-height:80vh; overflow-y:auto;">
      <h3>Select songs</h3>
      <div id="songSelectList"></div>
      <button class="btn" id="confirmSelectionBtn">Add to Playlist</button>
      <button class="btn" style="background:#ccc; margin-top:8px;" id="cancelSelectionBtn">Cancel</button>
    </div>
  </div>
</div>

<script>
  (() => {
    const dbName = 'OrcaPlayerDB';
    let db, allSongs = [], playlists = [], currentPlaylist = [], currentIndex = -1;
    let audio = new Audio(), isPlaying = false, repeatMode = 'off', shuffleMode = false;
    let currentTab = 'music', selectedPlaylistId = null, directoryHandle = null;
    const BATCH_SIZE = 50;

    // DOM refs
    const $ = (id) => document.getElementById(id);
    const contentArea = $('contentArea'), miniPlayer = $('miniPlayer'), miniThumb = $('miniThumb');
    const miniTitle = $('miniTitle'), miniArtist = $('miniArtist'), miniPlayBtn = $('miniPlayBtn');
    const playerFullscreen = $('playerFullscreen'), cdContainer = $('cdContainer'), cdArt = $('cdArt');
    const nowTitle = $('nowTitle'), nowArtist = $('nowArtist'), seekBar = $('seekBar'), seekFill = $('seekFill');
    const currentTimeEl = $('currentTime'), totalTimeEl = $('totalTime'), playPauseBtn = $('playPauseBtn');
    const prevBtn = $('prevBtn'), nextBtn = $('nextBtn'), loveBtn = $('loveBtn'), repeatBtn = $('repeatBtn'), shuffleBtn = $('shuffleBtn');
    const tabs = document.querySelectorAll('.tab'), settingsBtn = $('settingsBtn');
    const permOverlay = $('permOverlay'), permSelectBtn = $('permSelectBtn');
    const searchToggleBtn = $('searchToggleBtn'), searchBarContainer = $('searchBarContainer'), searchInput = $('searchInput');

    // IndexedDB
    async function openDB() {
      return new Promise((res, rej) => {
        const req = indexedDB.open(dbName, 2);
        req.onupgradeneeded = e => {
          db = e.target.result;
          if (!db.objectStoreNames.contains('songs')) db.createObjectStore('songs', { keyPath: 'id' });
          if (!db.objectStoreNames.contains('playlists')) db.createObjectStore('playlists', { keyPath: 'id' });
          if (!db.objectStoreNames.contains('settings')) db.createObjectStore('settings', { keyPath: 'key' });
        };
        req.onsuccess = e => { db = e.target.result; res(); };
        req.onerror = rej;
      });
    }
    async function loadFromDB() {
      const tx = db.transaction(['songs','playlists','settings'], 'readonly');
      allSongs = await new Promise(res => { const r = tx.objectStore('songs').getAll(); r.onsuccess = () => res(r.result || []); });
      playlists = await new Promise(res => { const r = tx.objectStore('playlists').getAll(); r.onsuccess = () => res(r.result || []); });
      const dirSetting = await new Promise(res => { const r = tx.objectStore('settings').get('directoryHandle'); r.onsuccess = () => res(r.result); });
      if (dirSetting?.handle) {
        try { if ((await dirSetting.handle.queryPermission({mode:'readwrite'})) === 'granted') directoryHandle = dirSetting.handle; else directoryHandle = null; }
        catch { directoryHandle = null; }
      }
      await tx.done;
      // إخفاء شاشة الصلاحية إذا كانت الأغاني موجودة (حتى بدون صلاحية مؤقتاً لحين طلبها عند التشغيل)
      if (allSongs.length > 0 || directoryHandle) permOverlay.classList.add('hidden');
      renderContent();
    }
    async function saveSongsToDB() {
      const tx = db.transaction('songs','readwrite'), store = tx.objectStore('songs');
      await store.clear();
      for (let s of allSongs) await store.put(s);
      await tx.done;
    }
    async function savePlaylistsToDB() {
      const tx = db.transaction('playlists','readwrite'), store = tx.objectStore('playlists');
      await store.clear();
      for (let p of playlists) await store.put(p);
      await tx.done;
    }
    async function saveDirectoryHandle(handle) {
      const tx = db.transaction('settings','readwrite');
      await tx.objectStore('settings').put({key:'directoryHandle', handle});
      await tx.done;
    }

    function generateId() { return Date.now().toString(36) + Math.random().toString(36).substr(2); }

    // Permission & Scan
    async function requestDirectory() {
      try {
        const handle = await window.showDirectoryPicker({ mode: 'readwrite' });
        directoryHandle = handle;
        await saveDirectoryHandle(handle);
        permOverlay.classList.add('hidden');
        await fastScanAndDisplay(handle);
      } catch(e) {
        if (!allSongs.length) permOverlay.classList.remove('hidden');
      }
    }

    async function fastScanAndDisplay(dirHandle) {
      const audioFiles = [];
      async function collect(handle, path='') {
        for await (const entry of handle.values()) {
          if (entry.kind === 'file' && entry.name.match(/\.(mp3|m4a|flac|ogg|wav|aac)$/i))
            audioFiles.push({ handle: entry, relativePath: path + entry.name });
          else if (entry.kind === 'directory') await collect(entry, path + entry.name + '/');
        }
      }
      await collect(dirHandle);
      allSongs = audioFiles.map(({ handle, relativePath }) => ({
        id: generateId(),
        title: handle.name.replace(/\.[^/.]+$/, ""),
        artist: 'Unknown Artist',
        album: 'Unknown Album',
        picture: null,
        duration: 0,
        fileRef: relativePath,
        _metaLoaded: false
      }));
      await saveSongsToDB();
      renderContent();

      // Background metadata
      const total = audioFiles.length;
      let processed = 0;
      for (let i = 0; i < total; i += BATCH_SIZE) {
        const batch = audioFiles.slice(i, i + BATCH_SIZE);
        const results = await Promise.allSettled(batch.map(async ({ handle, relativePath }) => {
          const file = await handle.getFile();
          return await extractMetadata(file, handle.name, relativePath);
        }));
        results.forEach((res, idx) => {
          if (res.status === 'fulfilled') {
            allSongs[i + idx] = { ...allSongs[i + idx], ...res.value, _metaLoaded: true };
          }
          processed++;
        });
        if (currentTab === 'music') updateMusicListMetadata();
      }
      await saveSongsToDB();
      renderContent();
    }

    function updateMusicListMetadata() {
      document.querySelectorAll('.song-item').forEach(el => {
        const song = allSongs.find(s => s.id === el.dataset.id);
        if (!song || !song._metaLoaded) return;
        const titleEl = el.querySelector('.song-title'), artistEl = el.querySelector('.song-artist'), thumbEl = el.querySelector('.song-thumb');
        if (titleEl) titleEl.textContent = song.title;
        if (artistEl) artistEl.textContent = song.artist + (song.fileRef ? ' · ' + song.fileRef.split('/').pop() : '');
        if (thumbEl) thumbEl.innerHTML = song.picture ? `<img src="${song.picture}" alt="">` : '<i class="fa-solid fa-music"></i>';
        const loadEl = el.querySelector('.meta-loading');
        if (loadEl) loadEl.remove();
      });
    }

    function extractMetadata(file, fileName, relativePath) {
      return new Promise(resolve => {
        const base = { title: fileName.replace(/\.[^/.]+$/, ""), artist: 'Unknown Artist', album: 'Unknown Album', picture: null };
        try {
          new jsmediatags.Reader(file).setTagsToRead(['title','artist','album','picture']).read({
            onSuccess: tag => {
              let pic = null;
              if (tag.tags.picture) {
                const { data, format } = tag.tags.picture;
                let str = '';
                for (let i=0;i<data.length;i++) str += String.fromCharCode(data[i]);
                pic = `data:${format};base64,${btoa(str)}`;
              }
              resolve({ title: tag.tags.title || base.title, artist: tag.tags.artist || base.artist, album: tag.tags.album || base.album, picture: pic });
            },
            onError: () => resolve(base)
          });
        } catch { resolve(base); }
      });
    }

    async function getFileByRef(ref) {
      if (!directoryHandle) return null;
      const parts = ref.split('/').filter(p => p);
      let cur = directoryHandle;
      for (let i=0; i<parts.length; i++) {
        if (i === parts.length-1) {
          try { return await cur.getFileHandle(parts[i]); } catch { return null; }
        } else {
          try { cur = await cur.getDirectoryHandle(parts[i]); } catch { return null; }
        }
      }
    }

    async function playSongById(songId) {
      const song = allSongs.find(s => s.id === songId);
      if (!song) return;
      if (!directoryHandle) {
        alert('Music folder permission needed. Please tap the gear icon to select the folder.');
        return requestDirectory();
      }
      const fh = await getFileByRef(song.fileRef);
      if (!fh) { alert('File missing. Please reselect music folder.'); return; }
      const file = await fh.getFile();
      audio.src = URL.createObjectURL(file);
      audio.load();
      try {
        await audio.play();
        isPlaying = true; updatePlayPauseIcons(); cdContainer.classList.add('playing');
      } catch(e) { console.warn('Play error', e); }
      updateNowPlayingInfo(song);
      currentIndex = currentPlaylist.indexOf(songId);
      if (currentIndex === -1) { currentPlaylist = [songId]; currentIndex = 0; }
      if ('mediaSession' in navigator) {
        navigator.mediaSession.metadata = new MediaMetadata({
          title: song.title, artist: song.artist, album: song.album,
          artwork: song.picture ? [{ src: song.picture }] : []
        });
        navigator.mediaSession.setActionHandler('previoustrack', playPrevious);
        navigator.mediaSession.setActionHandler('nexttrack', playNext);
        navigator.mediaSession.setActionHandler('play', () => audio.play());
        navigator.mediaSession.setActionHandler('pause', () => audio.pause());
      }
      updateLoveButton(songId); updateMiniPlayer(song);
      playerFullscreen.classList.add('open'); miniPlayer.classList.remove('hidden');
    }

    function updateNowPlayingInfo(song) {
      nowTitle.textContent = song.title; nowArtist.textContent = song.artist;
      cdArt.innerHTML = song.picture ? `<img src="${song.picture}">` : '<i class="fa-solid fa-music"></i>';
      totalTimeEl.textContent = '0:00'; currentTimeEl.textContent = '0:00'; seekFill.style.width = '0%';
    }
    function updateMiniPlayer(song) {
      miniTitle.textContent = song.title; miniArtist.textContent = song.artist;
      miniThumb.innerHTML = song.picture ? `<img src="${song.picture}">` : '<i class="fa-solid fa-music"></i>';
    }
    function updatePlayPauseIcons() {
      playPauseBtn.className = `fa-solid fa-${isPlaying?'pause':'play'} ctrl-btn play-btn`;
      miniPlayBtn.className = `fa-solid fa-${isPlaying?'pause':'play'} mini-play`;
    }

    function playPrevious() {
      if (!currentPlaylist.length) return;
      let idx = currentIndex - 1; if (idx < 0) idx = currentPlaylist.length - 1;
      playSongById(currentPlaylist[idx]);
    }
    function playNext() {
      if (!currentPlaylist.length) return;
      let idx;
      if (shuffleMode) idx = Math.floor(Math.random() * currentPlaylist.length);
      else {
        idx = currentIndex + 1;
        if (idx >= currentPlaylist.length) {
          if (repeatMode === 'all') idx = 0;
          else { audio.pause(); isPlaying = false; updatePlayPauseIcons(); cdContainer.classList.remove('playing'); return; }
        }
      }
      playSongById(currentPlaylist[idx]);
    }
    function toggleLove() {
      if (currentIndex < 0) return;
      const id = currentPlaylist[currentIndex];
      let fav = playlists.find(p => p.name === 'Favorites');
      if (!fav) { fav = { id: generateId(), name: 'Favorites', songIds: [id] }; playlists.push(fav); savePlaylistsToDB(); loveBtn.classList.add('active'); }
      else {
        if (fav.songIds.includes(id)) { fav.songIds = fav.songIds.filter(x => x !== id); loveBtn.classList.remove('active'); }
        else { fav.songIds.push(id); loveBtn.classList.add('active'); }
        savePlaylistsToDB();
      }
    }
    function updateLoveButton(id) {
      const fav = playlists.find(p => p.name === 'Favorites');
      loveBtn.classList.toggle('active', !!fav?.songIds.includes(id));
    }

    // RENDERING with search support
    function getFilteredSongs() {
      const query = searchInput?.value?.trim().toLowerCase() || '';
      if (!query) return allSongs;
      return allSongs.filter(s => 
        s.title.toLowerCase().includes(query) ||
        s.artist.toLowerCase().includes(query) ||
        s.album.toLowerCase().includes(query) ||
        s.fileRef.toLowerCase().includes(query)
      );
    }

    function renderContent() {
      switch(currentTab) {
        case 'music': renderMusic(); break;
        case 'playlist': renderPlaylistList(); break;
        case 'album': renderAlbums(); break;
        case 'artist': renderArtists(); break;
      }
    }

    function renderMusic() {
      selectedPlaylistId = null;
      const songs = getFilteredSongs();
      let html = songs.map(song => `
        <div class="song-item" data-id="${song.id}">
          <div class="song-thumb">${song.picture ? `<img src="${song.picture}">` : '<i class="fa-solid fa-music"></i>'}</div>
          <div class="song-info">
            <div class="song-title">${escapeHtml(song.title)}</div>
            <div class="song-artist">${escapeHtml(song.artist)} ${song.fileRef ? '· '+song.fileRef.split('/').pop() : ''}</div>
            ${!song._metaLoaded ? '<div class="meta-loading">Loading...</div>' : ''}
          </div>
        </div>`).join('');
      if (!songs.length) html = '<p style="text-align:center;margin-top:40px;">No songs found.</p>';
      contentArea.innerHTML = html;
      document.querySelectorAll('.song-item').forEach(el => {
        el.addEventListener('click', () => {
          currentPlaylist = allSongs.map(s => s.id);
          playSongById(el.dataset.id);
        });
      });
    }

    function renderPlaylistList() {
      let html = '<button class="btn" id="newPlaylistBtn" style="margin-bottom:16px;"><i class="fa-solid fa-plus"></i> Create Playlist</button>';
      playlists.forEach(pl => {
        html += `<div class="song-item" data-playlist-id="${pl.id}">
          <div class="song-thumb"><i class="fa-solid fa-list-ul"></i></div>
          <div class="song-info"><div class="song-title">${escapeHtml(pl.name)}</div><div class="song-artist">${pl.songIds.length} songs</div></div>
        </div>`;
      });
      contentArea.innerHTML = html;
      $('newPlaylistBtn')?.addEventListener('click', openCreatePlaylistModal);
      document.querySelectorAll('[data-playlist-id]').forEach(el => {
        el.addEventListener('click', () => { selectedPlaylistId = el.dataset.playlistId; renderPlaylistSongs(selectedPlaylistId); });
      });
    }

    function renderPlaylistSongs(plId) {
      const pl = playlists.find(p => p.id === plId); if (!pl) return;
      let html = `<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
        <i class="fa-solid fa-arrow-left" style="font-size:1.5rem;cursor:pointer;" id="backToPlaylists"></i>
        <h3>${escapeHtml(pl.name)}</h3></div>
        <button class="btn" id="playPlaylistBtn"><i class="fa-solid fa-play"></i> Play All</button>`;
      pl.songIds.forEach(id => {
        const song = allSongs.find(s => s.id === id); if (!song) return;
        html += `<div class="song-item" data-id="${song.id}">
          <div class="song-thumb">${song.picture ? `<img src="${song.picture}">` : '<i class="fa-solid fa-music"></i>'}</div>
          <div class="song-info"><div class="song-title">${escapeHtml(song.title)}</div><div class="song-artist">${escapeHtml(song.artist)}</div></div>
        </div>`;
      });
      contentArea.innerHTML = html;
      $('backToPlaylists')?.addEventListener('click', () => { selectedPlaylistId = null; renderPlaylistList(); });
      $('playPlaylistBtn')?.addEventListener('click', () => { if(pl.songIds.length){ currentPlaylist=[...pl.songIds]; playSongById(pl.songIds[0]); } });
      document.querySelectorAll('.song-item[data-id]').forEach(el => {
        el.addEventListener('click', () => { currentPlaylist=[...pl.songIds]; playSongById(el.dataset.id); });
      });
    }

    function renderAlbums() {
      const map = new Map();
      allSongs.forEach(s => { if(!map.has(s.album)) map.set(s.album, []); map.get(s.album).push(s); });
      let html = '<div class="grid-cards">';
      for (let [album, songs] of map.entries()) {
        const pic = songs.find(s => s.picture)?.picture || null;
        html += `<div class="card" data-album="${escapeHtml(album)}">
          ${pic ? `<img src="${pic}">` : '<i class="fa-solid fa-compact-disc fa-music"></i>'}
          <div class="card-name">${escapeHtml(album)}</div><div class="card-count">${songs.length} songs</div>
        </div>`;
      }
      html += '</div>'; contentArea.innerHTML = html;
      document.querySelectorAll('.card[data-album]').forEach(card => {
        card.addEventListener('click', () => {
          const album = card.dataset.album;
          const songs = allSongs.filter(s => s.album === album);
          contentArea.innerHTML = `<h3>${escapeHtml(album)}</h3>` + songs.map(s => `
            <div class="song-item" data-id="${s.id}">
              <div class="song-thumb">${s.picture ? `<img src="${s.picture}">` : '<i class="fa-solid fa-music"></i>'}</div>
              <div class="song-info"><div class="song-title">${escapeHtml(s.title)}</div><div class="song-artist">${escapeHtml(s.artist)}</div></div>
            </div>`).join('');
          document.querySelectorAll('.song-item').forEach(el => el.addEventListener('click', () => { currentPlaylist = songs.map(s=>s.id); playSongById(el.dataset.id); }));
        });
      });
    }

    function renderArtists() {
      const map = new Map();
      allSongs.forEach(s => { if(!map.has(s.artist)) map.set(s.artist, []); map.get(s.artist).push(s); });
      let html = '<div class="grid-cards">';
      for (let [artist, songs] of map.entries()) {
        const pic = songs.find(s => s.picture)?.picture || null;
        html += `<div class="card" data-artist="${escapeHtml(artist)}">
          ${pic ? `<img src="${pic}">` : '<i class="fa-solid fa-user-music fa-music"></i>'}
          <div class="card-name">${escapeHtml(artist)}</div><div class="card-count">${songs.length} songs</div>
        </div>`;
      }
      html += '</div>'; contentArea.innerHTML = html;
      document.querySelectorAll('.card[data-artist]').forEach(card => {
        card.addEventListener('click', () => {
          const artist = card.dataset.artist;
          const songs = allSongs.filter(s => s.artist === artist);
          contentArea.innerHTML = `<h3>${escapeHtml(artist)}</h3>` + songs.map(s => `
            <div class="song-item" data-id="${s.id}">
              <div class="song-thumb">${s.picture ? `<img src="${s.picture}">` : '<i class="fa-solid fa-music"></i>'}</div>
              <div class="song-info"><div class="song-title">${escapeHtml(s.title)}</div><div class="song-artist">${escapeHtml(s.artist)}</div></div>
            </div>`).join('');
          document.querySelectorAll('.song-item').forEach(el => el.addEventListener('click', () => { currentPlaylist = songs.map(s=>s.id); playSongById(el.dataset.id); }));
        });
      });
    }

    function openCreatePlaylistModal() { $('playlistModal').classList.remove('hidden'); $('playlistNameInput').value = ''; }
    $('createPlaylistBtn')?.addEventListener('click', async () => {
      const name = $('playlistNameInput').value.trim(); if (!name) return;
      $('playlistModal').classList.add('hidden');
      const selectList = $('songSelectList');
      selectList.innerHTML = allSongs.map(s => `<div class="song-item" data-id="${s.id}"><div class="playlist-checkbox"></div><div class="song-thumb">${s.picture?`<img src="${s.picture}">`:'<i class="fa-solid fa-music"></i>'}</div><div class="song-info"><div class="song-title">${escapeHtml(s.title)}</div><div class="song-artist">${escapeHtml(s.artist)}</div></div></div>`).join('');
      $('songSelectModal').classList.remove('hidden');
      const selected = new Set();
      document.querySelectorAll('#songSelectList .song-item').forEach(el => {
        const cb = el.querySelector('.playlist-checkbox');
        el.addEventListener('click', e => { if(e.target===cb)return; cb.classList.toggle('checked'); if(cb.classList.contains('checked'))selected.add(el.dataset.id); else selected.delete(el.dataset.id); });
        cb.addEventListener('click', e => { e.stopPropagation(); cb.classList.toggle('checked'); if(cb.classList.contains('checked'))selected.add(el.dataset.id); else selected.delete(el.dataset.id); });
      });
      $('confirmSelectionBtn').onclick = () => {
        playlists.push({ id: generateId(), name, songIds: Array.from(selected) });
        savePlaylistsToDB(); $('songSelectModal').classList.add('hidden'); renderContent();
      };
    });
    $('cancelPlaylistBtn')?.addEventListener('click', ()=> $('playlistModal').classList.add('hidden'));
    $('cancelSelectionBtn')?.addEventListener('click', ()=> $('songSelectModal').classList.add('hidden'));

    function escapeHtml(t) { return String(t).replace(/[&<>"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[m]); }

    // EVENTS
    tabs.forEach(t => t.addEventListener('click', () => {
      tabs.forEach(x => x.classList.remove('active')); t.classList.add('active');
      currentTab = t.dataset.tab; selectedPlaylistId = null; renderContent();
    }));
    miniPlayer.addEventListener('click', () => playerFullscreen.classList.add('open'));
    $('closePlayerBtn').addEventListener('click', () => playerFullscreen.classList.remove('open'));
    playPauseBtn.addEventListener('click', () => {
      if (audio.paused) { audio.play(); isPlaying = true; cdContainer.classList.add('playing'); }
      else { audio.pause(); isPlaying = false; cdContainer.classList.remove('playing'); }
      updatePlayPauseIcons();
    });
    miniPlayBtn.addEventListener('click', e => { e.stopPropagation(); playPauseBtn.click(); });
    prevBtn.addEventListener('click', playPrevious); nextBtn.addEventListener('click', playNext);
    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      seekFill.style.width = (audio.currentTime/audio.duration)*100 + '%';
      currentTimeEl.textContent = formatTime(audio.currentTime);
      totalTimeEl.textContent = formatTime(audio.duration);
    });
    audio.addEventListener('ended', () => {
      if (repeatMode === 'one') { audio.currentTime = 0; audio.play(); }
      else playNext();
    });
    audio.addEventListener('play', () => { isPlaying = true; updatePlayPauseIcons(); cdContainer.classList.add('playing'); });
    audio.addEventListener('pause', () => { isPlaying = false; updatePlayPauseIcons(); cdContainer.classList.remove('playing'); });
    seekBar.addEventListener('click', e => {
      const rect = seekBar.getBoundingClientRect();
      audio.currentTime = (e.clientX - rect.left) / rect.width * audio.duration;
    });
    loveBtn.addEventListener('click', toggleLove);
    repeatBtn.addEventListener('click', () => {
      if (repeatMode === 'off') repeatMode = 'all';
      else if (repeatMode === 'all') repeatMode = 'one';
      else repeatMode = 'off';
      repeatBtn.classList.toggle('active', repeatMode !== 'off');
      repeatBtn.style.color = repeatMode === 'one' ? '#e74c3c' : '';
    });
    shuffleBtn.addEventListener('click', () => { shuffleMode = !shuffleMode; shuffleBtn.classList.toggle('active', shuffleMode); });
    settingsBtn.addEventListener('click', requestDirectory);
    permSelectBtn.addEventListener('click', requestDirectory);

    // Search toggle & live search
    searchToggleBtn.addEventListener('click', () => {
      searchBarContainer.classList.toggle('hidden');
      if (!searchBarContainer.classList.contains('hidden')) searchInput.focus();
      else { searchInput.value = ''; if (currentTab === 'music') renderMusic(); }
    });
    searchInput.addEventListener('input', () => {
      if (currentTab === 'music') renderMusic();
    });

    function formatTime(s) { const m = Math.floor(s/60), sec = Math.floor(s%60); return m + ':' + (sec<10?'0':'')+sec; }

    window.addEventListener('load', async () => {
      await openDB(); await loadFromDB();
      if (navigator.storage?.persist) navigator.storage.persist();
      // إظهار شاشة الصلاحية فقط إذا لا يوجد handle ولا أغاني مخزنة
      if (!directoryHandle && allSongs.length === 0) permOverlay.classList.remove('hidden');
    });
  })();
  
  if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('./sw.js')
    .then(reg => console.log('SW registered!', reg))
    .catch(err => console.log('SW failed', err));
}
</script>

</body>
</html>
